{
  "name": "rollipop-monorepo",
  "private": true,
  "workspaces": [
    "docs",
    "example",
    "packages/*"
  ],
  "scripts": {
    "roll": "yarn fmt && yarn lint && yarn typecheck:all && yarn test:all",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "typecheck:all": "yarn workspaces foreach --all --topological-dev run typecheck",
    "lint": "oxlint --config .oxlintrc.json --type-aware --deny-warnings",
    "lint:fix": "oxlint --config .oxlintrc.json --type-aware --deny-warnings --fix",
    "test:all": "yarn workspaces foreach --all --topological-dev --no-private run test",
    "build:all": "yarn workspaces foreach --all --topological-dev --no-private run build",
    "docs:dev": "yarn workspace docs dev",
    "docs:build": "yarn workspace docs build",
    "scripts:version": ".scripts/version.sh",
    "scripts:publish": ".scripts/publish.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.13.0"
}
